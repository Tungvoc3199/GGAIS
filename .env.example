NODE_ENV=development
PORT=3000
GEMINI_API_KEY=
ALLOW_DEV_REST_FALLBACK=false
VITE_ENABLE_DEMO_MODE=false

# Firebase App Check
# Production cần set site key reCAPTCHA v3/App Check thật trong hosting environment.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Chỉ dùng local dev. Không set trong production/CI.
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=

# Khi bật true trong CI/production, static security check sẽ fail nếu cấu hình demo/debug sai.
VITE_PRODUCTION_SECURITY_CHECK=false

# Do not commit real production secrets here. Use environment variables.
